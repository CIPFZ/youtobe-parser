# ===========================
# YouTube Parser Configuration
# ===========================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Network / Proxy ---
# Global proxy for accessing YouTube (e.g. socks5://127.0.0.1:1080)
GLOBAL_PROXY=

# --- YouTube cookies (optional, helps pass bot checks) ---
# Export YouTube cookies in Netscape format and place it under ./data/secrets on host
# Example: YOUTUBE_COOKIE_FILE=/app/secrets/youtube_cookies.txt
YOUTUBE_COOKIE_FILE=

# --- PO Token Provider ---
# If you run an external POT provider, configure it here.
# Example: http://host.docker.internal:4416
PO_TOKEN_SERVER=http://pot-provider:4416
# Optional proxy specifically for pot-provider container (HTTP/HTTPS proxy recommended)
POT_PROXY=
# Timeout for calling pot-provider /get_pot
PO_TOKEN_TIMEOUT_SECONDS=45

# --- OpenAI-compatible LLM (for SRT -> ASS translation) ---
# Required for /v1/translate to call your LLM provider
OPENAI_API_KEY=
# Compatible endpoint, e.g. https://api.openai.com/v1 or your gateway URL
OPENAI_BASE_URL=https://api.openai.com/v1
# Any chat-completions capable model name
OPENAI_MODEL=gpt-4o-mini

# --- Redis task store ---
REDIS_URL=redis://redis:6379/0
TASK_TTL_SECONDS=86400

# --- Concurrency ---
# Maximum number of simultaneous yt-dlp analysis tasks
MAX_CONCURRENT_DOWNLOADS=3
# Retry yt-dlp once without proxy when proxy refuses connection
RETRY_WITHOUT_PROXY_ON_REFUSED=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# host test: curl http://127.0.0.1:4416/health
