WORK_DIR=runtime
OUTPUT_NAME=final_output
METADATA_DIRNAME=metadata
COOKIE_FILE=
YTDLP_PROXY=socks5://127.0.0.1:7897
PLAYLIST_STRATEGY=first
YTDLP_VIDEO_FORMAT=bestvideo[ext=mp4][vcodec^=avc1]/bestvideo[ext=mp4]
YTDLP_AUDIO_FORMAT=bestaudio[ext=m4a]
FFMPEG_PATH=

WHISPER_MODEL=large-v3
WHISPER_MODEL_SOURCE=huggingface
WHISPER_MODELSCOPE_REPO=
WHISPER_MODEL_CACHE_DIR=runtime/models
WHISPER_DOWNLOAD_TO_LOCAL=true
WHISPER_DOWNLOAD_PROXY=socks5://127.0.0.1:7897
WHISPER_MODEL_FALLBACK_TO_MODELSCOPE=true
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=en
TRANSCRIBE_USE_VOCALS=false
TRANSCRIBE_VOCALS_FALLBACK_TO_ORIGINAL=true
TRANSCRIBE_SEPARATION_DIRNAME=transcribe_separated

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
TARGET_LANGUAGE=zh-CN
TRANSLATION_BATCH_SIZE=20

DISCOVERY_ENABLED=false
YOUTUBE_API_KEY=
DISCOVERY_TOPIC_TYPES=ai,tech,digital
DISCOVERY_TOPIC_AI_KEYWORDS=AI,artificial intelligence,LLM,OpenAI,Anthropic,Google DeepMind
DISCOVERY_TOPIC_TECH_KEYWORDS=technology,tech news,software engineering,cloud computing,startup tech
DISCOVERY_TOPIC_DIGITAL_KEYWORDS=gadgets,consumer tech,smartphone review,laptop review,digital products
DISCOVERY_KEYWORDS=
DISCOVERY_DAYS_BACK=3
DISCOVERY_MAX_RESULTS_PER_KEYWORD=25
DISCOVERY_TOP_N=20
DISCOVERY_MIN_VIEWS=50000
DISCOVERY_MIN_COMMENTS=100
DISCOVERY_MIN_DURATION_SEC=180
DISCOVERY_MAX_DURATION_SEC=3600
DISCOVERY_HTTP_RETRIES=3
DISCOVERY_HTTP_RETRY_BACKOFF_SEC=1.2
DISCOVERY_DB_PATH=runtime/discovery/discovery.db

LOG_LEVEL=INFO
LOG_FILE=runtime/logs/pipeline.log

PIPELINE_ENABLE_DUBBING=true

# independent dubbing pipeline
DUBBING_WORK_DIRNAME=dubbing
DUB_TARGET_LANGUAGE=zh-CN
DUBBING_VOICE_VOLUME=1.0
DUBBING_BGM_VOLUME=1.0
DUBBING_MAX_SPEED=1.2
DUBBING_MIN_SPEED=0.95
DUBBING_MAX_CHARS_PER_SEC=4.5
DUBBING_SEGMENT_GAP_SEC=0.6
DUBBING_MAX_SEGMENT_DURATION_SEC=12.0
DUBBING_CROSSFADE_SEC=0.04
DUBBING_PRESET=default
DUBBING_TIMING_MODE=relaxed
DUBBING_MAX_ADVANCE_SEC=1.2
DUBBING_MIN_GAP_SEC=0.05
DUBBING_REFLOW_SUBTITLES=true
DUBBING_SUBTITLE_MAX_CHARS=20
DUBBING_SUBTITLE_MAX_DURATION_SEC=3.6
DUBBING_SUBTITLE_MAX_GAP_SEC=0.25
DUBBING_TRIM_TTS_SILENCE=true
DUBBING_TTS_SILENCE_THRESHOLD=0.01
DUBBING_TTS_KEEP_LEAD_SEC=0.02
DUBBING_TTS_KEEP_TAIL_SEC=0.08
DUBBING_PRESERVE_FULL_TEXT=true
DUBBING_DISABLE_TIME_STRETCH=true

SEPARATION_BACKEND=demucs
DEMUCS_COMMAND=demucs
DEMUCS_MODEL=htdemucs_ft
DEMUCS_DEVICE=auto
DEMUCS_CUDA_FALLBACK_TO_CPU=true
DEMUCS_CACHE_DIR=models/demucs

TTS_PROVIDER=openai
TTS_OPENAI_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_EDGE_VOICE=zh-CN-XiaoxiaoNeural
# default female
TTS_VOICE_GENDER=female
TTS_EDGE_VOICE_FEMALE=zh-CN-XiaoxiaoNeural
TTS_EDGE_VOICE_MALE=zh-CN-YunxiNeural
